{
  "hooks": {
    "PreToolUse": [
      { "matcher": "Bash",       "hooks": [ { "type": "command", "command": "__WS__/hooks/block-dangerous.sh" } ] },
      { "matcher": "Edit|Write", "hooks": [ { "type": "command", "command": "__WS__/hooks/protect-files.sh" } ] }
    ],
    "PostToolUse": [
      { "matcher": "Bash", "hooks": [ { "type": "command", "command": "__WS__/hooks/log-commands.sh" } ] }
    ]
  }
}
